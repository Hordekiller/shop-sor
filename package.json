{
  "name": "atlas-shop",
  "version": "0.2.0",
  "private": true,
  "description": "پلتفرم فروشگاهی مدرن و کامل با NestJS، Next.js و Turborepo",
  "license": "MIT",
  "author": "فروشگاه اطلس",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hordekiller/shop-sor.git"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "dev:api": "npm run dev -w @atlas-shop/api",
    "dev:web": "npm run dev -w @atlas-shop/web",
    "dev:admin": "npm run dev -w @atlas-shop/admin",
    "db:migrate": "npm run db:migrate -w @atlas-shop/api",
    "db:generate": "npm run db:generate -w @atlas-shop/api"
  },
  "devDependencies": {
    "prettier": "^3.2.0",
    "turbo": "^2.0.0"
  },
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
