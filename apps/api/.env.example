# ===== Database =====
# PostgreSQL connection string (required)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/atlas_shop?schema=public"

# ===== JWT Authentication =====
# Secret key for signing JWT tokens (required - change in production)
JWT_SECRET="your-secret-key-change-in-production"
# Token expiration time
JWT_EXPIRES_IN="7d"

# ===== Server =====
# API server port
PORT=8000
# Allowed CORS origins (comma-separated)
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"

# ===== Payment Gateway: Zarinpal =====
# Merchant ID from Zarinpal dashboard
ZARINPAL_MERCHANT_ID="00000000-0000-0000-0000-000000000000"
# Callback URL after payment
ZARINPAL_CALLBACK_URL="http://localhost:8000/api/v1/payments/verify"

# ===== SMTP / Email =====
# SMTP server configuration for sending emails
SMTP_HOST="localhost"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@atlas-shop.com"

# ===== Encryption =====
# Key for encrypting sensitive data (32 characters recommended)
ENCRYPTION_KEY="atlas-shop-dev-encryption-key-32chars!!"
