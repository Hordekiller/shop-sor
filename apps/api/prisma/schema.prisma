generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────

enum UserRole {
  CUSTOMER
  ADMIN
  SUPER_ADMIN
}

enum ProductType {
  SIMPLE
  VARIABLE
  DIGITAL
}

enum ProductStatus {
  IN_STOCK
  OUT_OF_STOCK
  PRE_ORDER
}

enum ProductPublishStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum OrderPaymentStatus {
  UNPAID
  PAID
  REFUNDED
  FAILED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum ReturnRequestStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum ReturnRequestReason {
  DEFECTIVE
  WRONG_ITEM
  NOT_AS_DESCRIBED
  OTHER
}

enum VendorOrderStatus {
  PENDING
  PAID
  SETTLED
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

enum WalletTransactionType {
  DEPOSIT
  WITHDRAW
  WITHDRAWAL
  REFUND
  BONUS
  PAYMENT
  ADMIN_ADJUST
}

enum BlogPostStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
}

enum MenuLocation {
  HEADER
  FOOTER
  MEGA_MENU
}

enum CouponType {
  PERCENT
  FIXED
}

enum PageStatus {
  DRAFT
  PUBLISHED
}

enum PageType {
  LANDING
  BLOG_POST
  SHOP_LANDING
  CATEGORY_PAGE
  CUSTOM
}

enum PopupType {
  CENTER
  BOTTOM_SHEET
  TOP_BANNER
}

enum PopupDisplayMode {
  ONCE
  EACH_VISIT
  DAILY
}

// ── Models ────────────────────────────────

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  phone     String?  @unique
  nationalId String?
  birthDate String?
  password  String
  role      UserRole @default(CUSTOMER)
  avatar    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  orders    Order[]
  reviews   Review[]
  addresses Address[]
  stockMovements StockMovement[]
  wishlist       Wishlist[]
  ownedShop Shop?
  coupons   Coupon[]
  couponUsages   CouponUsage[]
  reviewLikes    ReviewLike[]
  wallet    Wallet?
  cartItems  CartItem[]
  mediaFiles MediaFile[]
  blogPosts  BlogPost[]
  blogComments BlogComment[]
  notifications Notification[]
  stockAlerts   StockAlert[]
  savedItems    SavedItem[]
  pageRevisions PageRevision[]
  returnRequests ReturnRequest[]
}

model Shop {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  description String?
  logo        String?
  cover       String?
  isActive    Boolean  @default(false)
  commission  Float    @default(10.0)
  ownerId     Int      @unique
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  owner        User           @relation(fields: [ownerId], references: [id])
  products     Product[]
  vendorOrders VendorOrder[]
}

model Brand {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  slug        String   @unique
  description String?
  logo        String?
  metaTitle   String?
  metaDesc    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  products    Product[]

  @@map("brands")
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  description String?
  image       String?
  metaTitle   String?
  metaDesc    String?
  parentId    Int?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  parent    Category?         @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  Category[]        @relation("CategoryHierarchy")
  mainProducts      Product[]               @relation("ProductMainCategory")
  products          ProductCategory[]
  megaMenuConfig    MegaMenuCategoryConfig?
}

model Product {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  shortDescription String?
  description String?
  price       Decimal  @default(0) @db.Decimal(12, 0)
  salePrice   Decimal? @db.Decimal(12, 0)
  discountPercent Float?
  discountStartAt DateTime? @db.Timestamptz
  discountEndAt   DateTime? @db.Timestamptz
  viewCount       Int      @default(0)
  sku         String?  @unique
  barcode     String?  @unique
  stock       Int      @default(0)
  lowStockThreshold Int @default(10)
  minOrderQty Int      @default(1)
  maxOrderQty Int      @default(0)
  type        ProductType @default(SIMPLE)
  status      ProductStatus @default(IN_STOCK)
  isActive    Boolean  @default(true)
  weight      Float?
  length      Float?
  width       Float?
  height      Float?
  filePath    String?
  images      Json     @default("[]")
  videoUrl    String?
  tags        Json     @default("[]")
  attributes  Json     @default("{}")
  publishStatus ProductPublishStatus @default(PUBLISHED)
  relatedProductIds Json @default("[]")
  metaTitle   String?
  metaDesc    String?
  averageRating Float  @default(0)
  numReviews    Int    @default(0)
  numExpertReviews Int @default(0)
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  categoryId  Int
  brandId     Int?
  shopId      Int?
  category    Category         @relation("ProductMainCategory", fields: [categoryId], references: [id])
  brand       Brand?           @relation(fields: [brandId], references: [id])
  shop        Shop?            @relation(fields: [shopId], references: [id])
  categories  ProductCategory[]
  orderItems  OrderItem[]
  reviews     Review[]
  variants    ProductVariant[]
  attrDefs    ProductAttribute[]
  stockMovements StockMovement[]
  wishlist       Wishlist[]
  cartItems      CartItem[]
  specifications ProductSpecification[]
  stockAlerts    StockAlert[]
  savedItems     SavedItem[]
}

model ProductCategory {
  productId  Int
  categoryId Int
  sortOrder  Int      @default(0)

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@map("product_categories")
}

model ProductSpecification {
  id        Int    @id @default(autoincrement())
  productId Int
  name      String
  value     String
  sortOrder Int    @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_specifications")
}

model Order {
  id              Int      @id @default(autoincrement())
  orderNumber     String   @unique
  subtotal        Decimal  @db.Decimal(12, 0)
  shippingCost    Decimal  @default(0) @db.Decimal(12, 0)
  taxAmount       Decimal  @default(0) @db.Decimal(12, 0)
  discount        Decimal  @default(0) @db.Decimal(12, 0)
  total           Decimal  @db.Decimal(12, 0)
  status          OrderStatus @default(PENDING)
  paymentStatus   OrderPaymentStatus @default(UNPAID)
  paymentMethod   String?
  shippingMethod  String?
  trackingCode    String?
  notes           String?
  paidAt          DateTime? @db.Timestamptz
  deliveredAt     DateTime? @db.Timestamptz
  shippingAddress String?
  addressId   Int?
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  userId       Int
  user         User          @relation(fields: [userId], references: [id])
  address      Address?      @relation(fields: [addressId], references: [id])
  items        OrderItem[]
  payments     Payment[]
  vendorOrders VendorOrder[]
  stockMovements StockMovement[]
  reviews      Review[]
  couponUsages CouponUsage[]
  returnRequests ReturnRequest[]
}

model ReturnRequest {
  id          Int      @id @default(autoincrement())
  orderId     Int
  userId      Int
  reason      ReturnRequestReason
  description String?
  status      ReturnRequestStatus @default(PENDING)
  items       Json
  refundAmount Decimal? @db.Decimal(12, 0)
  adminNote   String?
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  order Order @relation(fields: [orderId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([orderId])
  @@index([userId])
  @@map("return_requests")
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  quantity  Int     @default(1)
  price     Decimal @db.Decimal(12, 0)
  total     Decimal @db.Decimal(12, 0)
  variantName String?

  orderId   Int
  productId Int
  variantId Int?
  order     Order          @relation(fields: [orderId], references: [id])
  product   Product        @relation(fields: [productId], references: [id])
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
}

model ProductVariant {
  id         Int      @id @default(autoincrement())
  productId  Int
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name       String
  sku        String?  @unique
  price      Decimal? @db.Decimal(12, 0)
  stock      Int      @default(0)
  attributes Json     @default("{}")
  images     Json     @default("[]")
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now()) @db.Timestamptz
  updatedAt  DateTime @updatedAt @db.Timestamptz

  orderItems    OrderItem[]
  stockMovements StockMovement[]
}

model Payment {
  id          Int      @id @default(autoincrement())
  amount      Decimal  @db.Decimal(12, 0)
  authority   String?
  referenceId String?
  status      PaymentStatus @default(PENDING)
  gateway     String?
  paidAt      DateTime? @db.Timestamptz
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  orderId Int
  order   Order @relation(fields: [orderId], references: [id])
}

model Review {
  id         Int      @id @default(autoincrement())
  rating     Int      @default(5)
  title      String?
  comment    String?
  pros       String?
  cons       String?
  isApproved Boolean  @default(false)
  isVerified Boolean  @default(false)
  isExpert   Boolean  @default(false)
  expertName String?
  likes      Int      @default(0)
  createdAt  DateTime @default(now()) @db.Timestamptz
  updatedAt  DateTime @updatedAt @db.Timestamptz

  userId    Int
  productId Int
  orderId   Int?

  user      User         @relation(fields: [userId], references: [id])
  product   Product      @relation(fields: [productId], references: [id])
  order     Order?       @relation(fields: [orderId], references: [id])
  media     ReviewMedia[]
  likesRel  ReviewLike[]

  @@unique([userId, productId])
}

model ReviewMedia {
  id       Int    @id @default(autoincrement())
  url      String
  type     String @default("image")
  reviewId Int
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

model MediaFile {
  id           Int      @id @default(autoincrement())
  url          String
  filename     String
  originalName String
  mimetype     String
  size         Int
  width        Int?
  height       Int?
  format       String?
  thumbnailUrl String?
  smallUrl     String?
  mediumUrl    String?
  largeUrl     String?
  xlargeUrl    String?
  sourceType   String   @default("admin")
  uploadedById Int?
  attachedTo   String?
  alt          String?
  caption      String?
  isApproved   Boolean  @default(true)
  createdAt    DateTime @default(now()) @db.Timestamptz
  updatedAt    DateTime @updatedAt @db.Timestamptz

  uploader User?  @relation(fields: [uploadedById], references: [id])
  fonts    Font[]
}

model ReviewLike {
  id       Int @id @default(autoincrement())
  userId   Int
  reviewId Int
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id])

  @@unique([userId, reviewId])
}

model Wishlist {
  id        Int      @id @default(autoincrement())
  userId    Int
  productId Int
  createdAt DateTime @default(now()) @db.Timestamptz

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Address {
  id           Int      @id @default(autoincrement())
  userId       Int
  title        String   @default("خانه")
  receiverName String
  phone        String
  province     String
  city         String
  postalCode   String
  addressText  String
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now()) @db.Timestamptz

  user User @relation(fields: [userId], references: [id])
  orders Order[]
}

model Coupon {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  type      CouponType @default(PERCENT)
  value     Decimal  @db.Decimal(12, 0)
  minOrder  Decimal  @default(0) @db.Decimal(12, 0)
  maxUses   Int?
  maxUsesPerUser Int      @default(1)
  maxDiscountAmount Decimal? @db.Decimal(12, 0)
  usedCount Int      @default(0)
  totalDiscount Decimal @default(0) @db.Decimal(12, 0)
  startsAt  DateTime? @db.Timestamptz
  expiresAt DateTime? @db.Timestamptz
  isActive  Boolean  @default(true)
  applicableProducts Json @default("[]")
  applicableCategories Json @default("[]")
  createdAt DateTime @default(now()) @db.Timestamptz

  userId    Int?
  user      User?          @relation(fields: [userId], references: [id])
  usages    CouponUsage[]
}

model CouponUsage {
  id       Int      @id @default(autoincrement())
  couponId Int
  userId   Int
  orderId  Int
  discount Decimal  @default(0) @db.Decimal(12, 0)
  usedAt   DateTime @default(now()) @db.Timestamptz

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])
  order  Order  @relation(fields: [orderId], references: [id])

  @@unique([couponId, orderId])
}

model VendorOrder {
  id        Int      @id @default(autoincrement())
  amount    Decimal  @db.Decimal(12, 0)
  commission Decimal @db.Decimal(12, 0)
  netAmount Decimal  @db.Decimal(12, 0)
  status    VendorOrderStatus @default(PENDING)
  settledAt DateTime? @db.Timestamptz
  createdAt DateTime @default(now()) @db.Timestamptz

  shopId  Int
  orderId Int
  shop    Shop  @relation(fields: [shopId], references: [id])
  order   Order @relation(fields: [orderId], references: [id])
}

model ShippingMethod {
  id             Int      @id @default(autoincrement())
  name           String
  slug           String   @unique
  description    String?
  basePrice      Decimal  @default(0) @db.Decimal(12, 0)
  freeThreshold  Decimal  @default(0) @db.Decimal(12, 0)
  estimatedDays  String?
  weightCost     Decimal  @default(0) @db.Decimal(12, 0)
  sortOrder      Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now()) @db.Timestamptz
  updatedAt      DateTime @updatedAt @db.Timestamptz

  @@map("shipping_methods")
}

model SiteConfig {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model SiteSlide {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  bgColor     String   @default("from-[#ef4056] to-[#d8364a]")
  image       String?
  link        String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz
}

model Menu {
  id        Int      @id @default(autoincrement())
  name      String
  location  MenuLocation @default(HEADER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  items         MenuItem[]
  megaMenuConfig MegaMenuConfig?

  @@map("menus")
}

model MenuItem {
  id        Int       @id @default(autoincrement())
  menuId    Int
  menu      Menu      @relation(fields: [menuId], references: [id], onDelete: Cascade)
  parentId  Int?
  parent    MenuItem? @relation("MenuItemHierarchy", fields: [parentId], references: [id])
  children  MenuItem[] @relation("MenuItemHierarchy")
  title     String
  linkType  String    @default("custom_url")
  linkValue String    @default("")
  icon      String?
  image     String?
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now()) @db.Timestamptz

  @@map("menu_items")
}

model PageSection {
  id        Int      @id @default(autoincrement())
  type      String   @default("carousel_style_1")
  title     String?
  subtitle  String?
  sortOrder Int      @default(0)
  settings  Json     @default("{}")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  blocks    SectionBlock[]

  @@map("page_sections")
}

model SectionBlock {
  id         Int          @id @default(autoincrement())
  sectionId  Int
  section    PageSection  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  title      String?
  subtitle   String?
  image      String?
  videoUrl   String?
  link       String?
  badge      String?
  badgeColor String?
  sortOrder  Int          @default(0)
  settings   Json         @default("{}")
  createdAt  DateTime     @default(now()) @db.Timestamptz

  @@map("section_blocks")
}

model ProductAttribute {
  id        Int      @id @default(autoincrement())
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  values    Json     @default("[]")
  createdAt DateTime @default(now()) @db.Timestamptz

  @@map("product_attributes")
}

model ShopSettings {
  id               String @id @default("singleton")
  shopName         String @default("فروشگاه اطلس")
  shopLogo         String?
  shopFavicon      String?
  shopDescription  String?
  contactPhone     String?
  contactEmail     String?
  contactAddress   String?
  socialInstagram  String?
  socialTelegram   String?
  socialWhatsapp   String?
  metaTitle        String?
  metaDescription  String?
  zarinpalMerchant String?
  smsProvider      String?
  smsApiKey        String?
  orderSmsTemplate String?
  minOrderAmount   Decimal  @default(0) @db.Decimal(12, 0)
  taxPercent       Float    @default(0)
  walletBonusPercent Float  @default(0)
  walletBonusFromDate DateTime? @db.Timestamptz
  walletBonusToDate   DateTime? @db.Timestamptz
  updatedAt        DateTime @updatedAt @db.Timestamptz
}

model StockMovement {
  id        Int     @id @default(autoincrement())
  type      StockMovementType @default(IN)
  quantity  Int
  reason    String?
  stockAfter Int?
  createdAt DateTime @default(now()) @db.Timestamptz

  productId Int
  variantId Int?
  orderId   Int?
  createdBy Int

  product   Product           @relation(fields: [productId], references: [id])
  variant   ProductVariant?   @relation(fields: [variantId], references: [id])
  order     Order?            @relation(fields: [orderId], references: [id])
  creator   User              @relation(fields: [createdBy], references: [id])
}

model Wallet {
  id        Int      @id @default(autoincrement())
  balance   Decimal  @default(0) @db.Decimal(12, 0)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  userId       Int                @unique
  user         User               @relation(fields: [userId], references: [id])
  transactions WalletTransaction[]
}

model WalletTransaction {
  id          Int      @id @default(autoincrement())
  amount      Decimal  @db.Decimal(12, 0)
  type        WalletTransactionType @default(DEPOSIT)
  description String?
  refType     String?
  refId       Int?
  balanceAfter Decimal? @db.Decimal(12, 0)
  createdAt   DateTime @default(now()) @db.Timestamptz

  walletId Int
  wallet   Wallet @relation(fields: [walletId], references: [id])
}

model Page {
  id          Int        @id @default(autoincrement())
  title       String
  slug        String     @unique
  type        PageType   @default(LANDING)
  status      PageStatus @default(DRAFT)
  content     String?
  contentJson Json?
  metaTitle   String?
  metaDesc    String?
  isActive    Boolean    @default(true)
  publishAt   DateTime?  @db.Timestamptz
  unpublishAt DateTime?  @db.Timestamptz
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now()) @db.Timestamptz
  updatedAt   DateTime   @updatedAt @db.Timestamptz

  revisions   PageRevision[]
}

model PageRevision {
  id           Int      @id @default(autoincrement())
  pageId       Int
  title        String
  contentJson  String
  authorId     Int?
  note         String?
  createdAt    DateTime @default(now()) @db.Timestamptz
  page         Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  author       User?    @relation(fields: [authorId], references: [id])

  @@index([pageId, createdAt])
  @@map("page_revisions")
}

model Font {
  id         Int      @id @default(autoincrement())
  name       String
  source     String   @default("link")
  url        String?
  mediaId    Int?
  filepath   String?
  weights    String   @default("400")
  subsets    String?
  isActive   Boolean  @default(true)
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now()) @db.Timestamptz
  updatedAt  DateTime @updatedAt @db.Timestamptz

  media      MediaFile? @relation(fields: [mediaId], references: [id], onDelete: SetNull)

  @@map("fonts")
}

model Redirect {
  id        Int      @id @default(autoincrement())
  source    String   @unique
  target    String
  type      Int      @default(301)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  @@map("redirects")
}

model Otp {
  id        Int      @id @default(autoincrement())
  phone     String
  code      String
  expiresAt DateTime @db.Timestamptz
  verified  Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz

  @@index([phone, code])
  @@map("otps")
}

// ─── Blog ─────────────────────────────────

model BlogPost {
  id            Int      @id @default(autoincrement())
  title         String
  slug          String   @unique
  content       String?
  excerpt       String?
  featuredImage String?
  status        BlogPostStatus @default(DRAFT)
  publishedAt   DateTime? @db.Timestamptz
  viewCount     Int      @default(0)
  metaTitle     String?
  metaDesc      String?
  createdAt     DateTime @default(now()) @db.Timestamptz
  updatedAt     DateTime @updatedAt @db.Timestamptz

  authorId Int
  author   User  @relation(fields: [authorId], references: [id])

  categories   BlogPostCategory[]
  tags         BlogPostTag[]
  comments     BlogComment[]

  @@map("blog_posts")
}

model BlogCategory {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now()) @db.Timestamptz

  parentId  Int?
  parent    BlogCategory?   @relation("BlogCategoryHierarchy", fields: [parentId], references: [id])
  children  BlogCategory[]  @relation("BlogCategoryHierarchy")
  posts     BlogPostCategory[]

  @@map("blog_categories")
}

model BlogTag {
  id    Int    @id @default(autoincrement())
  name  String @unique
  slug  String @unique
  posts BlogPostTag[]

  @@map("blog_tags")
}

model BlogPostCategory {
  postId     Int
  categoryId Int

  post     BlogPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  category BlogCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([postId, categoryId])
  @@map("blog_post_categories")
}

model BlogPostTag {
  postId Int
  tagId  Int

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@map("blog_post_tags")
}

model BlogComment {
  id        Int      @id @default(autoincrement())
  content   String
  name      String?
  email     String?
  website   String?
  isApproved Boolean @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz

  parentId Int?
  parent   BlogComment?  @relation("BlogCommentHierarchy", fields: [parentId], references: [id])
  replies  BlogComment[] @relation("BlogCommentHierarchy")

  postId Int
  post   BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  userId Int?
  user   User?   @relation(fields: [userId], references: [id])

  @@map("blog_comments")
}

model MegaMenuConfig {
  id             Int     @id @default(autoincrement())
  menuId         Int?    @unique
  showCategories Boolean @default(true)
  showBrands     Boolean @default(true)
  tabs           Json    @default("[\"categories\",\"brands\"]")
  sidebarTitle   String? @default("ویژه")
  sidebarLinks   Json    @default("[]")
  sidebarBanner  String?
  sidebarBannerLink String?
  sidebarBannerSize String? @default("300×400")
  updatedAt      DateTime @updatedAt @db.Timestamptz

  menu Menu? @relation(fields: [menuId], references: [id])

  @@map("mega_menu_config")
}

model MegaMenuCategoryConfig {
  id          Int     @id @default(autoincrement())
  categoryId  Int     @unique
  icon        String?
  iconType    String  @default("iconify")
  sidebarBanner String?
  sidebarBannerLink String?
  sidebarLinks Json    @default("[]")

  category Category @relation(fields: [categoryId], references: [id])

  @@map("mega_menu_category_configs")
}

model Story {
  id          Int      @id @default(autoincrement())
  title       String
  subtitle    String?
  image       String?
  videoUrl    String?
  link        String?
  bgColor     String   @default("linear-gradient(135deg, #667eea 0%, #764ba2 100%)")
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  @@map("stories")
}

model Popup {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  image       String?
  link        String?
  btnText     String   @default("مشاهده")
  type        PopupType @default(CENTER)
  displayMode PopupDisplayMode @default(ONCE)
  delay       Int      @default(3000)
  startAt     DateTime? @db.Timestamptz
  endAt       DateTime? @db.Timestamptz
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  @@map("popups")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String
  title     String
  message   String?
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model NotificationTemplate {
  id              Int      @id @default(autoincrement())
  type            String   @unique
  titleTemplate   String
  messageTemplate String?
  emailSubject    String?
  emailHtml       String?
  smsTemplate     String?
  channels        String   @default("in_app,email")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz

  @@map("notification_templates")
}

model CartItem {
  id         Int      @id @default(autoincrement())
  quantity   Int      @default(1)
  createdAt  DateTime @default(now()) @db.Timestamptz
  updatedAt  DateTime @updatedAt @db.Timestamptz

  userId    Int
  productId Int
  variantId Int      @default(0)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId, variantId])
}

model StockAlert {
  id        Int      @id @default(autoincrement())
  userId    Int
  productId Int
  variantId Int      @default(0)
  notified  Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId, variantId])
  @@index([productId, notified])
  @@map("stock_alerts")
}

model SavedItem {
  id        Int      @id @default(autoincrement())
  userId    Int
  productId Int
  variantId Int      @default(0)
  createdAt DateTime @default(now()) @db.Timestamptz

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId, variantId])
  @@map("saved_items")
}
